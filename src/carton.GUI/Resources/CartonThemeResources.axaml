<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <ResourceDictionary>
      <FontFamily x:Key="SymbolThemeFontFamily">avares://FluentAvalonia/Fonts#Symbols</FontFamily>
      <SolidColorBrush x:Key="CartonAccentBrush" Color="#0078D4" />
      <SolidColorBrush x:Key="CartonAccentForegroundBrush" Color="White" />
      <!-- 选中/展开态边框用的弱化强调色(70% alpha)。运行时由 ThemeService 跟随当前强调色更新,此处为首帧初值(默认强调色 #0078D7 的 70%) -->
      <SolidColorBrush x:Key="CartonAccentBorderBrush" Color="#B30078D7" />

      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="CartonControlBackgroundChromeMediumBrush" Color="#FFF1F1F1" />
          <SolidColorBrush x:Key="CartonControlBackgroundChromeMediumLowBrush" Color="#FFF7F7F7" />
          <SolidColorBrush x:Key="CartonControlBackgroundChromeHighBrush" Color="#FFFFFFFF" />
          <SolidColorBrush x:Key="CartonSettingsItemBackgroundBrush" Color="#FFFFFFFF" />
          <SolidColorBrush x:Key="CartonSettingsItemPointerOverBackgroundBrush" Color="#FFF9F9F9" />
          <SolidColorBrush x:Key="CartonSettingsItemBorderBrush" Color="#16000000" />
          <SolidColorBrush x:Key="CartonControlBackgroundBaseLowBrush" Color="#14000000" />
          <SolidColorBrush x:Key="CartonControlBackgroundAltHighBrush" Color="#FFFFFFFF" />
          <SolidColorBrush x:Key="CartonControlBackgroundAltMediumHighBrush" Color="#FFF5F5F5" />
          <SolidColorBrush x:Key="CartonControlForegroundBaseHighBrush" Color="#FF1F1F1F" />
          <SolidColorBrush x:Key="CartonControlForegroundBaseMediumHighBrush" Color="#CC000000" />
          <SolidColorBrush x:Key="CartonControlForegroundBaseMediumBrush" Color="#99000000" />
          <SolidColorBrush x:Key="CartonControlForegroundBaseMediumLowBrush" Color="#66000000" />
          <SolidColorBrush x:Key="CartonControlForegroundBaseLowBrush" Color="#33000000" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="CartonControlBackgroundChromeMediumBrush" Color="#FF2B2B2B" />
          <SolidColorBrush x:Key="CartonControlBackgroundChromeMediumLowBrush" Color="#FF242424" />
          <SolidColorBrush x:Key="CartonControlBackgroundChromeHighBrush" Color="#FF1F1F1F" />
          <SolidColorBrush x:Key="CartonSettingsItemBackgroundBrush" Color="#FF2B2B2B" />
          <SolidColorBrush x:Key="CartonSettingsItemPointerOverBackgroundBrush" Color="#FF323232" />
          <SolidColorBrush x:Key="CartonSettingsItemBorderBrush" Color="#18FFFFFF" />
          <SolidColorBrush x:Key="CartonControlBackgroundBaseLowBrush" Color="#26FFFFFF" />
          <SolidColorBrush x:Key="CartonControlBackgroundAltHighBrush" Color="#FF1E1E1E" />
          <SolidColorBrush x:Key="CartonControlBackgroundAltMediumHighBrush" Color="#FF2A2A2A" />
          <SolidColorBrush x:Key="CartonControlForegroundBaseHighBrush" Color="#FFFFFFFF" />
          <SolidColorBrush x:Key="CartonControlForegroundBaseMediumHighBrush" Color="#CCFFFFFF" />
          <SolidColorBrush x:Key="CartonControlForegroundBaseMediumBrush" Color="#99FFFFFF" />
          <SolidColorBrush x:Key="CartonControlForegroundBaseMediumLowBrush" Color="#66FFFFFF" />
          <SolidColorBrush x:Key="CartonControlForegroundBaseLowBrush" Color="#33FFFFFF" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Styles.Resources>
</Styles>
