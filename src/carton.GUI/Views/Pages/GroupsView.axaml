<UserControl x:Name="GroupsViewRoot"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:carton.ViewModels"
             xmlns:helpers="using:carton.GUI.Helpers"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="600"
             x:Class="carton.Views.Pages.GroupsView"
             x:DataType="vm:GroupsViewModel">

  <Grid RowDefinitions="Auto,Auto,*">
    <Border Grid.Row="0"
            Background="{DynamicResource CartonControlBackgroundChromeMediumBrush}"
            Padding="16">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock Text="{DynamicResource Navigation.Groups}"
                   FontSize="24"
                   FontWeight="SemiBold"/>
        <ProgressBar Width="80"
                     Height="4"
                     IsVisible="{Binding IsLoading}"
                     IsIndeterminate="True"
                     Margin="12,0,0,0"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Background="{DynamicResource CartonControlBackgroundChromeMediumBrush}"
            BorderBrush="{DynamicResource CartonControlForegroundBaseMediumLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="10,6">
      <TextBlock Text="{Binding StatusMessage}"
                 VerticalAlignment="Center"/>
    </Border>

    <ScrollViewer Grid.Row="2"
                  Background="{DynamicResource CartonControlBackgroundChromeMediumBrush}">
      <ItemsControl Margin="16,8,16,12"
                    ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:GroupItemViewModel">
            <Border Margin="0,0,0,6"
                    Padding="14,10"
                    CornerRadius="12"
                    BorderThickness="1"
                    VerticalAlignment="Top"
                    PointerPressed="OnGroupItemPressed"
                    Classes.expanded="{Binding IsExpanded}">
              <Border.Styles>
                <Style Selector="Border">
                  <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundAltHighBrush}"/>
                  <Setter Property="BorderBrush" Value="{DynamicResource CartonControlForegroundBaseMediumLowBrush}"/>
                </Style>
                <Style Selector="Border.expanded">
                  <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundChromeHighBrush}"/>
                  <Setter Property="BorderBrush" Value="{DynamicResource CartonAccentBorderBrush}"/>
                </Style>
              </Border.Styles>

              <Grid RowDefinitions="Auto,Auto"
                    VerticalAlignment="Top"
                    RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto"
                      Background="Transparent"
                      ColumnSpacing="8">
                  <StackPanel Grid.Column="0"
                              Spacing="6">
                    <WrapPanel Orientation="Horizontal"
                               VerticalAlignment="Center"
                               ItemSpacing="6"
                               LineSpacing="6">
                      <TextBlock helpers:EmojiTextHelper.Text="{Binding Name}"
                                 FontSize="16"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center"/>
                      <Border Padding="7,1"
                              CornerRadius="999"
                              Background="{DynamicResource CartonControlBackgroundChromeMediumBrush}">
                        <TextBlock Text="{Binding Type}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
                      </Border>
                      <Border Padding="7,1"
                              CornerRadius="999"
                              Background="{DynamicResource CartonControlBackgroundChromeMediumBrush}">
                        <TextBlock Text="{Binding ItemCount}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
                      </Border>
                    </WrapPanel>

                    <TextBlock helpers:EmojiTextHelper.Prefix="{DynamicResource Groups.Label.Current}"
                               helpers:EmojiTextHelper.Text="{Binding SelectedOutbound}"
                               FontSize="12"
                               Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
                  </StackPanel>

                  <Border Grid.Column="1"
                          VerticalAlignment="Top"
                          Padding="8,4"
                          CornerRadius="8"
                          Cursor="Hand"
                          PointerPressed="OnGroupTestDelayPressed">
                    <Border.Styles>
                      <Style Selector="Border">
                        <Setter Property="Background" Value="Transparent"/>
                      </Style>
                      <Style Selector="Border:pointerover">
                        <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundBaseLowBrush}"/>
                      </Style>
                    </Border.Styles>
                    <Grid MinWidth="28"
                          Height="16"
                          VerticalAlignment="Center">
                      <TextBlock Text="..."
                                 IsVisible="{Binding IsTesting}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
                      <Path Width="14"
                            Height="14"
                            IsVisible="{Binding !IsTesting}"
                            Stretch="Uniform"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="1,0,0,0"
                            Fill="{DynamicResource CartonControlForegroundBaseMediumBrush}"
                            Data="M13 2L5 13H11L10 22L18 11H12L13 2Z"/>
                    </Grid>
                  </Border>

                  <Grid Grid.Column="2"
                        Width="32"
                        Height="28"
                        VerticalAlignment="Top"
                        IsHitTestVisible="False">
                    <Grid IsVisible="{Binding IsCollapsed}"
                          Width="32"
                          Height="28"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                      <Path Width="14"
                            Height="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Stroke="{DynamicResource CartonControlForegroundBaseHighBrush}"
                            StrokeThickness="1.8"
                            StrokeLineCap="Round"
                            Data="M 5 3.5 L 9.5 7 L 5 10.5"/>
                    </Grid>
                    <Grid IsVisible="{Binding IsExpanded}"
                          Width="32"
                          Height="28"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                      <Path Width="14"
                            Height="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Stroke="{DynamicResource CartonControlForegroundBaseHighBrush}"
                            StrokeThickness="1.8"
                            StrokeLineCap="Round"
                            Data="M 3.5 5 L 7 9.5 L 10.5 5"/>
                    </Grid>
                  </Grid>
                </Grid>

                <StackPanel Grid.Row="1"
                            IsVisible="{Binding IsCollapsed}"
                            Spacing="6">
                  <ItemsControl ItemsSource="{Binding CollapsedPreviewItems}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                   ItemSpacing="5"
                                   LineSpacing="5"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="vm:OutboundCacheSnapshot">
                        <Grid Width="12"
                              Height="12"
                              ToolTip.Tip="{Binding Tag}">
                          <Border CornerRadius="2"
                                  Background="{Binding Delay, Converter={StaticResource LatencyForegroundConverter}}"/>
                          <Border Width="5"
                                  Height="5"
                                  Background="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding IsSelected}"/>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>

                <ListBox x:Name="ExpandedProxiesList"
                         Grid.Row="1"
                         Margin="0,0,0,-4"
                         VerticalAlignment="Top"
                         BorderThickness="0"
                         Padding="0"
                         Background="Transparent"
                         SelectionMode="Single"
                         SizeChanged="OnExpandedProxiesListSizeChanged"
                         IsVisible="{Binding IsExpanded}"
                         ItemsSource="{Binding ItemRows}">
                  <ListBox.Styles>
                    <Style Selector="ListBox#ExpandedProxiesList > ListBoxItem">
                      <Setter Property="Padding" Value="0"/>
                      <Setter Property="Margin" Value="0"/>
                      <Setter Property="Background" Value="Transparent"/>
                      <Setter Property="BorderBrush" Value="Transparent"/>
                      <Setter Property="BorderThickness" Value="0"/>
                      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                      <Setter Property="Template">
                        <ControlTemplate>
                          <ContentPresenter Content="{TemplateBinding Content}"
                                            ContentTemplate="{TemplateBinding ContentTemplate}"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </ControlTemplate>
                      </Setter>
                    </Style>
                    <Style Selector="ListBox#ExpandedProxiesList > ListBoxItem:pointerover">
                      <Setter Property="Background" Value="Transparent"/>
                      <Setter Property="BorderBrush" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBox#ExpandedProxiesList > ListBoxItem:selected">
                      <Setter Property="Background" Value="Transparent"/>
                      <Setter Property="BorderBrush" Value="Transparent"/>
                    </Style>
                  </ListBox.Styles>
                  <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                  </ListBox.ItemsPanel>
                  <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:OutboundItemRowViewModel">
                      <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="vm:OutboundItemViewModel">
                            <Border x:Name="ProxyItemBorder"
                                    Width="{Binding ElementName=ExpandedProxiesList, Path=Bounds.Width, Converter={StaticResource ResponsiveItemWidthConverter}, ConverterParameter=16}"
                                    Margin="0,5,0,5"
                                    Padding="0"
                                    CornerRadius="12"
                                    HorizontalAlignment="Stretch"
                                    Classes.selected="{Binding IsSelected}"
                                    ToolTip.ShowDelay="1500"
                                    ToolTip.BetweenShowDelay="-1"
                                    ToolTip.Placement="Right"
                                    ToolTip.HorizontalOffset="12">
                              <ToolTip.Tip>
                                <ToolTip IsHitTestVisible="False">
                                  <TextBlock Text="{Binding Tag}"
                                             MaxWidth="280"
                                             TextWrapping="Wrap"
                                             IsHitTestVisible="False"/>
                                </ToolTip>
                              </ToolTip.Tip>
                              <Border.Styles>
                                <Style Selector="Border">
                                  <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundAltMediumHighBrush}"/>
                                  <Setter Property="BorderBrush" Value="Transparent"/>
                                  <Setter Property="BorderThickness" Value="1"/>
                                </Style>
                                <Style Selector="Border.hovered:not(.selected)">
                                  <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundBaseLowBrush}"/>
                                </Style>
                                <Style Selector="Border.selected">
                                  <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundChromeHighBrush}"/>
                                  <Setter Property="BorderBrush" Value="{DynamicResource CartonAccentBorderBrush}"/>
                                  <Setter Property="BorderThickness" Value="1"/>
                                </Style>
                              </Border.Styles>

                              <Grid>
                                <Border x:Name="ProxySelectSurface"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        PointerEntered="OnProxySelectSurfacePointerEntered"
                                        PointerExited="OnProxySelectSurfacePointerExited"
                                        PointerPressed="OnProxySelectPressed">
                                </Border>

                                <Border Background="{DynamicResource CartonAccentBrush}"
                                        CornerRadius="12"
                                        Opacity="0.12"
                                        IsHitTestVisible="False"
                                        IsVisible="{Binding IsSelected}"/>

                                <StackPanel Margin="14,12"
                                            Spacing="10"
                                            IsHitTestVisible="False">
                                  <TextBlock helpers:EmojiTextHelper.Text="{Binding Tag}"
                                             FontSize="13"
                                             FontWeight="SemiBold"
                                             MaxLines="1"
                                             TextTrimming="CharacterEllipsis"/>
                                  <TextBlock Text="{Binding Type}"
                                              FontSize="10"
                                              Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
                                </StackPanel>

                                <Border Margin="0,0,14,8"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Padding="8,4"
                                        CornerRadius="8"
                                        PointerPressed="OnProxyTestDelayPressed"
                                        Cursor="Hand">
                                  <Border.Styles>
                                    <Style Selector="Border">
                                      <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                    <Style Selector="Border:pointerover">
                                      <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundBaseLowBrush}"/>
                                    </Style>
                                  </Border.Styles>
                                  <Grid MinWidth="28"
                                        Height="16"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DelayDisplay}"
                                               IsVisible="{Binding ShowDelayText}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding Delay, Converter={StaticResource LatencyForegroundConverter}}"/>
                                    <Path Width="12"
                                          Height="12"
                                          IsVisible="{Binding ShowDelayIcon}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Margin="1,0,0,0"
                                          Stretch="Uniform"
                                          Fill="{DynamicResource CartonControlForegroundBaseMediumBrush}"
                                          Data="M13 2L5 13H11L10 22L18 11H12L13 2Z"/>
                                  </Grid>
                                </Border>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>

</UserControl>
